{
  "expo": {
    "name": "NakaMobile",
    "slug": "nakamobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A237E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nakaanalytics.nakamobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow NakaMobile to use your location for naka deployment.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow NakaMobile to use your location for naka deployment."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A237E"
      },
      "package": "com.nakaanalytics.nakamobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow NakaMobile to use your location for naka deployment tracking."
        }
      ]
    ]
  }
}
